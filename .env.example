LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_TIMEOUT_SECONDS=360
OLLAMA_LLM_RETRIES=2
OLLAMA_LLM_MAX_PROMPT_CHARS=24000
GEN_MAX_CONTEXT_CHARS=18000

# OpenAI (optional)
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB
CHROMA_PATH=./chroma_db
